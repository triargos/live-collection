{
  "name": "@triargos/live-collection-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "clean": "tsc -b --clean",
    "prune-modules": "find . -type d -name node_modules -prune -exec rm -rf '{}' +",
    "playground": "pnpm --filter @triargos/live-collection-playground",
    "changeset": "changeset",
    "release": "pnpm -r build && changeset publish",
"prepare": "effect-tsgo patch"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "^4.0.0-beta.98",
    "typescript": "^7.0.2",
    "vitest": "^3.2.0",
"@effect/tsgo": "0.24.1"
  }
}
