{
  "name": "@triargos/live-collection",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "description": "Frontend live-sync engine: collection registry + scoping, persistence factory (TanStack DB), SSE/catchup client, sync broker, and bootstrap orchestration. Hero type: LiveCollection<T>.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triargos/live-collection.git",
    "directory": "packages/live-collection"
  },
  "scripts": {
    "typecheck": "tsc -b && tsc -p tsconfig.test.json",
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tanstack/db": "0.6.16",
    "@tanstack/db-sqlite-persistence-core": "0.2.8",
    "@triargos/live-collection-protocol": "workspace:*",
    "effect": "^4.0.0-beta.100",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0"
  }
}
