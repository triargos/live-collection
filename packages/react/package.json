{
  "name": "@triargos/live-collection-react",
  "version": "0.0.0",
  "type": "module",
  "description": "React bindings for @triargos/live-collection: useLiveCollection hook and runtime provider. Optional adapter so the core stays framework-neutral.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/triargos/live-collection.git",
    "directory": "packages/react"
  },
  "scripts": {
    "typecheck": "tsc -b && tsc -p tsconfig.test.json",
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@tanstack/react-db": "^0.1.85",
    "@triargos/live-collection": "workspace:*",
    "effect": "^4.0.0-beta.98"
  },
  "devDependencies": {
    "@triargos/live-collection-protocol": "workspace:*",
    "@types/react": "^19.2.15",
    "react": "^19.2.7"
  }
}
