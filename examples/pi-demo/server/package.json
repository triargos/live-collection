{
  "name": "@pi-demo/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "pi-demo reference backend: Effect HttpApi (CRUD + catchup) + raw SSE route over an in-memory sync event log and Effect PubSub bus.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.100",
    "@pi-demo/shared": "workspace:*",
    "@triargos/live-collection-protocol": "workspace:*",
    "effect": "^4.0.0-beta.100",
    "@triargos/live-collection-server": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "^4.0.0-beta.100",
    "@triargos/live-collection": "workspace:*",
    "@types/node": "^26.0.0",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
