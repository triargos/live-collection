    "@pi-demo/shared": "workspace:*",
    "@triargos/live-collection-protocol": "workspace:*",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@triargos/live-collection": "workspace:*",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "vitest": "^3.2.0"
  }
}
